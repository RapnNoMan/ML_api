{
  "headers": [
    {
      "source": "/.env",
      "headers": [
        { "key": "X-Internal-Service", "value": "config-loader" },
        { "key": "X-Env", "value": "production" },
        { "key": "X-Cluster", "value": "eu-west-1a" }
      ]
    },
    {
      "source": "/.env.local",
      "headers": [
        { "key": "X-Internal-Service", "value": "dotenv-sync" },
        { "key": "X-Env", "value": "staging-shadow" },
        { "key": "X-Cluster", "value": "eu-west-1b" }
      ]
    },
    {
      "source": "/admin",
      "headers": [
        { "key": "X-Internal-Service", "value": "iam-gateway" },
        { "key": "X-Env", "value": "prod-admin" },
        { "key": "X-Cluster", "value": "eu-central-1" }
      ]
    },
    {
      "source": "/debug",
      "headers": [
        { "key": "X-Internal-Service", "value": "trace-collector" },
        { "key": "X-Env", "value": "canary" },
        { "key": "X-Cluster", "value": "us-east-2" }
      ]
    },
    {
      "source": "/internal",
      "headers": [
        { "key": "X-Internal-Service", "value": "svc-mesh-router" },
        { "key": "X-Env", "value": "production" },
        { "key": "X-Cluster", "value": "us-west-2" }
      ]
    },
    {
      "source": "/config",
      "headers": [
        { "key": "X-Internal-Service", "value": "config-distributor" },
        { "key": "X-Env", "value": "prod-config" },
        { "key": "X-Cluster", "value": "ap-south-1" }
      ]
    },
    {
      "source": "/secret",
      "headers": [
        { "key": "X-Internal-Service", "value": "vault-proxy" },
        { "key": "X-Env", "value": "prod-secrets" },
        { "key": "X-Cluster", "value": "eu-north-1" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/.env", "destination": "/config_deadend.html" },
    { "source": "/.env.local", "destination": "/config_deadend.html" },
    { "source": "/admin", "destination": "/config_deadend.html" },
    { "source": "/debug", "destination": "/config_deadend.html" },
    { "source": "/internal", "destination": "/config_deadend.html" },
    { "source": "/config", "destination": "/config_deadend.html" },
    { "source": "/secret", "destination": "/config_deadend.html" },
    { "source": "/v1/chat", "destination": "/api/v1/chat" },
    { "source": "/v1/widget/:agent_id", "destination": "/api/v1/widget?agent_id=:agent_id" },
    { "source": "/v1/widget_checker/:agent_id", "destination": "/api/v1/widget_checker?agent_id=:agent_id" },
    { "source": "/v1/widget_dashboard/:agent_id", "destination": "/api/v1/widget_dashboard?agent_id=:agent_id" },
    { "source": "/v1/widget-dashboard/:agent_id", "destination": "/api/v1/widget_dashboard?agent_id=:agent_id" },
    { "source": "/v1/widget_grok/:agent_id", "destination": "/api/v1/widget?agent_id=:agent_id" },
    { "source": "/v1/widget-grok/:agent_id", "destination": "/api/v1/widget?agent_id=:agent_id" },
    { "source": "/v1/chat-page/:agent_id", "destination": "/api/v1/chat_page?agent_id=:agent_id" },
    { "source": "/v1/channels", "destination": "/api/v1/channels" },
    { "source": "/v1/ticket_tool_test", "destination": "/api/v1/ticket_tool_test" }
  ]
}
